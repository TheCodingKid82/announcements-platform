# Database
DATABASE_URL=postgresql://...

# Auth (phone OTP via Linq) — AUTH_SECRET keys the HMAC used to store OTP codes
AUTH_SECRET=...
LINQ_API_TOKEN=...
LINQ_FROM_NUMBER=+15555550100

# AI
ANTHROPIC_API_KEY=...

# Bulk SMS (Twilio — still used for fan-out delivery, separate from OTP)
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=...

# Email
RESEND_API_KEY=...
RESEND_FROM_ADDRESS=alerts@announcementsapp.com

# Cron
CRON_SECRET=...

# App
NEXT_PUBLIC_APP_URL=https://announcementsapp.com
